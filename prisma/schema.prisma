generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  HOUSEHOLD
  COLLECTOR
  RECYCLER
  ADMIN
}

enum RequestStatus {
  OPEN
  ASSIGNED
  ON_THE_WAY
  ARRIVED
  WEIGHED
  COMPLETED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PointType {
  EARNED
  REDEEMED
}

enum BatchStatus {
  AVAILABLE
  PURCHASE_REQUESTED
  APPROVED
  REJECTED
  DELIVERED
  COMPLETED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  fullName      String
  role          Role      @default(HOUSEHOLD)
  phone         String?
  address       String?
  latitude      Float?
  longitude     Float?
  isVerified    Boolean   @default(false)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  requestsAsHousehold   SampahRequest[]         @relation("HouseholdRequests")
  requestsAsCollector   SampahRequest[]         @relation("CollectorRequests")
  pointsLedger          PointsLedger[]
  reviewsGiven          Review[]                @relation("ReviewsGiven")
  reviewsReceived       Review[]                @relation("ReviewsReceived")
  verification          CollectorVerification?
  notifications         Notification[]
  commodityUpdates      CommodityPrice[]
  inventory             CollectorInventory[]
  batchesAsCollector    MaterialBatch[]          @relation("CollectorBatches")
  batchesAsRecycler     MaterialBatch[]          @relation("RecyclerBatches")

  @@map("users")
}

model CollectorInventory {
  id              String    @id @default(uuid())
  collectorId     String
  wasteType       String
  availableWeight Decimal   @default(0) @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  collector       User      @relation(fields: [collectorId], references: [id])

  @@unique([collectorId, wasteType], name: "collector_inventory_material")
  @@map("collector_inventory")
}

model MaterialBatch {
  id          String      @id @default(uuid()) @db.VarChar(36)
  collectorId String
  recyclerId  String?
  wasteType   String      @db.VarChar(50)
  totalWeight Decimal     @db.Decimal(10, 2)
  pricePerKg  Int
  grade       String      @default("B") @db.VarChar(20)
  location    String?     @db.Text
  description String?     @db.Text
  status      BatchStatus @default(AVAILABLE)
  createdAt   DateTime
  updatedAt   DateTime

  collector   User        @relation("CollectorBatches", fields: [collectorId], references: [id])
  recycler    User?       @relation("RecyclerBatches", fields: [recyclerId], references: [id])

  @@map("material_batches")
}

model SampahRequest {
  id              String        @id @default(uuid())
  householdId     String
  collectorId     String?
  status          RequestStatus @default(OPEN)
  sampahTypes     String
  estimatedWeight Float?
  actualWeight    Float?
  photoUrl        String?
  notes           String?
  latitude        Float?
  longitude       Float?
  addressDetail   String?
  contactPhone    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  household       User            @relation("HouseholdRequests", fields: [householdId], references: [id])
  collector       User?           @relation("CollectorRequests", fields: [collectorId], references: [id])
  pointsLedger    PointsLedger[]
  reviews         Review[]

  @@map("sampah_requests")
}

model PointsLedger {
  id          String      @id @default(uuid())
  userId      String
  amount      Int
  type        PointType
  requestId   String?
  description String?
  createdAt   DateTime    @default(now())

  user        User            @relation(fields: [userId], references: [id])
  request     SampahRequest?  @relation(fields: [requestId], references: [id])

  @@map("points_ledger")
}

model Review {
  id          String    @id @default(uuid())
  requestId   String
  reviewerId  String
  revieweeId  String
  rating      Int
  comment     String?
  createdAt   DateTime  @default(now())

  request     SampahRequest @relation(fields: [requestId], references: [id])
  reviewer    User          @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee    User          @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@map("reviews")
}

model CommodityPrice {
  id          String    @id @default(uuid())
  name        String
  pricePerKg  Int
  updatedBy   String
  updatedAt   DateTime  @updatedAt

  updater     User      @relation(fields: [updatedBy], references: [id])

  @@map("commodity_prices")
}

model CollectorVerification {
  id          String              @id @default(uuid())
  collectorId String              @unique
  ktpUrl      String?
  photoUrl    String?
  status      VerificationStatus  @default(PENDING)
  reviewedBy  String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  collector   User                @relation(fields: [collectorId], references: [id])

  @@map("collector_verifications")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  title       String
  message     String
  type        String
  referenceId String?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model UserBadge {
  id              String   @id @default(uuid())
  userId          String
  badgeName       String
  thresholdPoints Int
  earnedAt        DateTime

  @@unique([userId, badgeName], name: "user_badge_unique")
  @@map("user_badges")
}

model RewardRedemption {
  id          String   @id @default(uuid())
  userId      String
  rewardCode  String
  rewardName  String
  pointsCost  Int
  status      String
  createdAt   DateTime
  updatedAt   DateTime

  @@map("reward_redemptions")
}

model BidListing {
  id           String   @id @default(uuid()) @db.VarChar(36)
  sellerId     String   @db.VarChar(36)
  title        String
  description  String?  @db.Text
  contactName  String?
  contactPhone String?  @db.VarChar(50)
  photoUrl     String?  @db.Text
  minPrice     Int
  maxPrice     Int
  currentPrice Int
  priceStep    Int
  status       String?  @default("ACTIVE") @db.VarChar(20)
  winnerId     String?  @db.VarChar(36)
  expiresAt    DateTime
  createdAt    DateTime
  updatedAt    DateTime
  images       ListingImage[]

  @@map("bid_listings")
}

model ListingImage {
  id        String     @id @default(uuid()) @db.VarChar(36)
  listingId String     @db.VarChar(36)
  imageUrl  String     @db.Text
  sortOrder Int        @default(0)
  createdAt DateTime
  listing   BidListing @relation(fields: [listingId], references: [id])

  @@map("listing_images")
}
